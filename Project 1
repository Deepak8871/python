def fibonacci(n):
    """
    Generate Fibonacci series up to n terms.
    
    Args:
        n (int): Number of terms in the Fibonacci series
        
    Returns:
        list: List containing the Fibonacci series
    """
    if n <= 0:
        return []
    elif n == 1:
        return [0]
    
    fib_series = [0, 1]
    
    for i in range(2, n):
        next_value = fib_series[i-1] + fib_series[i-2]
        fib_series.append(next_value)
    
    return fib_series


def fibonacci_recursive(n):
    """
    Calculate the nth Fibonacci number using recursion.
    
    Args:
        n (int): Position in Fibonacci series
        
    Returns:
        int: The nth Fibonacci number
    """
    if n <= 0:
        return 0
    elif n == 1:
        return 1
    else:
        return fibonacci_recursive(n-1) + fibonacci_recursive(n-2)


def fibonacci_generator(n):
    """
    Generate Fibonacci series using a generator (memory efficient).
    
    Args:
        n (int): Number of terms to generate
        
    Yields:
        int: Next Fibonacci number
    """
    a, b = 0, 1
    count = 0
    
    while count < n:
        yield a
        a, b = b, a + b
        count += 1


# Example usage
if __name__ == "__main__":
    # Method 1: Iterative approach
    print("Fibonacci series (iterative):", fibonacci(10))
    
    # Method 2: Recursive approach for a single number
    print("10th Fibonacci number (recursive):", fibonacci_recursive(10))
    
    # Method 3: Generator approach
    print("Fibonacci series (generator):")
    for fib_num in fibonacci_generator(10):
        print(fib_num, end=" ")
    print()
